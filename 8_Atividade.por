programa
{
	
	funcao inicio()
	{
		// Declaracao
		cadeia Mae = "Tess"
		cadeia Filha = "Anna"
		cadeia Filha_X = Filha

		// Firula
		escreva("No filme Sexta-feira Muito Louca de 2003, conta a história de Tess e Anna, mãe e filha, e se elas trocassem de nomes? [Emoji de Cara assustada]")

		// Output
		Filha = Mae
		Mae = Filha_X

		escreva("\n" , "Trocaram [Emoji de Cara Surpresa]" , "\n" , "Mae: " , Mae, "\n" , "Filha: " , Filha)

		
	}
}
